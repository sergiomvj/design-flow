# Chave da API Gemini (necessária para IA)
GEMINI_API_KEY=3ry4ut52q6kr9ataacskol8i9r0a9ynr

# Secret para assinar os tokens JWT (use uma string longa e aleatória em produção!)
JWT_SECRET="troque-por-uma-string-segura-e-aleatoria"

# URL do banco de dados SQLite
# - Local: file:./prisma/dev.db
# - VPS (Docker): file:/app/data/production.db  ← gerenciado pelo docker-compose
DATABASE_URL="file:./prisma/dev.db"

# Porta do servidor (padrão: 3001)
PORT=3001
