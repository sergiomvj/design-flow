// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  password  String
  name      String
  role      String    @default("CLIENT") // ADMIN, DESIGNER, CLIENT
  projects  Project[] @relation("Requester")
  assigned  Project[] @relation("Designer")
  comments  Comment[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Project {
  id        String   @id @default(cuid())
  jobNumber String?  @unique
  status    String   @default("RECEIVED") // RECEIVED, IN_CREATION, WAITING_APPROVAL, APPROVED, IN_PRODUCTION, COMPLETED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Bloco 1: Requester Information
  requesterId      String
  requester        User    @relation("Requester", fields: [requesterId], references: [id])
  company          String
  requesterEmail   String
  phone            String
  internalSalesRep String?
  department       String
  contactMethod    String

  // Bloco 2: Project Type
  projectType     String
  category        String
  objective       String
  nature          String // New Design, Redesign, Adaptation, Revision

  // Bloco 3: Project Description
  description     String
  usage           String
  mainMessage     String
  headline        String?
  requiredText    String?
  mandatoryInfo   String?

  // Bloco 4: Technical Specifications
  dimensions      String
  unit            String
  material        String
  quantity        Int       @default(1)
  colors          String
  brandGuidelines String?
  finishing       String?

  // Bloco 5: References and Files
  logoUrl         String?
  fileUrls        String? 
  photoUrls       String?
  referenceLinks  String?
  likes           String?
  dislikes        String?

  // Bloco 6: Deadline and Priority
  deadline        DateTime?
  isRush          Boolean   @default(false)
  rushReason      String?
  eventDate       DateTime?

  // Bloco 7: Approval
  approverName    String?
  approverContact String?
  reviewerCount   Int?      @default(1)
  revisionCount   Int       @default(1)
  additionalChargesAware Boolean @default(false)

  // Bloco 8: Internal Control
  designerId      String?
  designer        User?     @relation("Designer", fields: [designerId], references: [id])
  priority        String?   @default("MEDIUM") // LOW, MEDIUM, HIGH, CRITICAL
  internalNotes   String?

  // Bloco 9: Final Confirmation
  isConfirmed     Boolean   @default(false)
  briefingAware   Boolean   @default(false)
  validationAware Boolean   @default(false)

  comments        Comment[]
}

model Comment {
  id        String   @id @default(cuid())
  text      String
  createdAt DateTime @default(now())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  projectId String
  project   Project  @relation(fields: [projectId], references: [id])
}
